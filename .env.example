# ===========================================
# 课记 (Course AI Notes) — 环境变量模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# --- 数据库 ---
# SQLite (开发阶段)
DATABASE_URL=sqlite+aiosqlite:///./keji.db
# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+asyncpg://keji:keji@localhost:5432/keji

# --- Redis (Celery 消息队列) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM 配置 (兼容 OpenAI Chat Completions API) ---
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- SiliconFlow 语音转写 ---
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_MODEL=FunAudioLLM/SenseVoiceSmall

# --- 文件存储 ---
UPLOAD_DIR=./uploads
MEDIA_DIR=./media

# --- 服务端口 ---
API_PORT=8000
FRONTEND_PORT=5173

# --- CORS (前端地址) ---
CORS_ORIGINS=http://localhost:5173
